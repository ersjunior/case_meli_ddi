# Postgres (container e Airflow)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# Porta exposta no seu PC (5432 costuma estar ocupada por Postgres local)
POSTGRES_PUBLISH_PORT=5433

# Airflow → Postgres (conn id postgres_default). Use postgresql:// — NÃO use postgresql+psycopg2 (Airflow quebra o hook).
# No Docker, o compose define host postgres:5432; localmente use localhost e a porta publicada (ex. 5433).
AIRFLOW_CONN_POSTGRES_DEFAULT=postgresql://airflow:airflow@postgres:5432/airflow

# DAG BashOperator (ingest)
PIPELINE_POSTGRES_URL=postgresql://airflow:airflow@postgres:5432/airflow

# Streamlit no Windows (fora do Docker): mesma porta do Postgres do compose
# DATABASE_URL=postgresql+psycopg2://airflow:airflow@localhost:5433/airflow

# Power BI — página "Embedded" (iframe). Altura opcional em pixels.
# POWERBI_EMBED_URL=https://app.powerbi.com/reportEmbed?reportId=...&groupId=...
# POWERBI_EMBED_HEIGHT=720
# POWERBI_EMBED_WIDTH=1180
# POWERBI_EMBED_WIDTH=100%

# --- Narrativa por LLM no Streamlit (opcional) ---
# false = textos fixos atuais; true = gera análises nos blocos que enviam contexto agregado.
LLM_NARRATIVE_ENABLED=false
# openai | local (API compatível OpenAI: Ollama / LM Studio / vLLM etc.)
LLM_PROVIDER=openai
LLM_TIMEOUT_SECONDS=90
# Nuvem OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# SLM local (ex.: Ollama: ollama serve → API em /v1)
# LLM_PROVIDER=local
# LLM_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# LLM_LOCAL_API_KEY=ollama
# LLM_LOCAL_MODEL=llama3.2
